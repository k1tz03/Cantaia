<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:type="MailApp">
  <Id>cantaia-outlook-addin-00000000-0000-0000-0000-000000000000</Id>
  <Version>1.0.0</Version>
  <ProviderName>Cantaia</ProviderName>
  <DefaultLocale>fr-CH</DefaultLocale>
  <DisplayName DefaultValue="Cantaia" />
  <Description DefaultValue="Assistant IA pour chef de projet construction" />
  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.1" />
    </Sets>
  </Requirements>
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://localhost:3000/outlook/taskpane" />
      </DesktopSettings>
    </Form>
  </FormSettings>
</OfficeApp>
