{
  "identifier": "default",
  "description": "Permissions par défaut pour Cantaia Desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "notification:default",
    "updater:allow-check",
    "updater:allow-download-and-install",
    "shell:allow-open",
    "process:allow-relaunch",
    "process:allow-exit"
  ]
}
