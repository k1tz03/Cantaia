{
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "echo 'Start Next.js manually: pnpm --filter @cantaia/web dev'",
    "devUrl": "http://localhost:3000",
    "frontendDist": "https://cantaia.io"
  },
  "productName": "Cantaia",
  "version": "1.0.0",
  "identifier": "io.cantaia.app",
  "app": {
    "windows": [
      {
        "title": "Cantaia",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://github.com/k1tz03/Cantaia/releases/latest/download/update.json"
      ]
    }
  }
}
